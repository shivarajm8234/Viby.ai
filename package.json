{
  "name": "viby-sec-auditor",
  "displayName": "Viby Security Auditor",
  "description": "Elite AI-powered security auditor and penetration tester.",
  "version": "0.0.1",
  "publisher": "viby",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:viby-sec-auditor.scan",
    "onView:viby-sec-auditor.sidebar"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "viby-sec-auditor.scan",
        "title": "Viby: Scan Workspace for Security Risks"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "viby-sec-dashboard",
          "title": "Viby Security",
          "icon": "media/icon.png"
        }
      ]
    },
    "views": {
      "viby-sec-dashboard": [
        {
          "type": "webview",
          "id": "viby-sec-auditor.sidebar",
          "name": "Security Dashboard"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/vscode": "^1.75.0",
    "@typescript-eslint/eslint-plugin": "^5.53.0",
    "@typescript-eslint/parser": "^5.53.0",
    "eslint": "^8.34.0",
    "typescript": "^4.9.5"
  },
  "dependencies": {
    "axios": "^1.3.4"
  }
}
